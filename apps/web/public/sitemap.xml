<?xml version="1.0" encoding="UTF-8"?>
<!--
  DropBeam sitemap. Each entry maps to a Vercel rewrite that serves
  index.html, and main.ts routes the page to the right in-app stage,
  swapping document.title and meta[name="description"] accordingly.

  When you have a real domain, replace the loc values with absolute URLs
  (https://dropbeam.app/...). Google accepts relative URLs in sitemaps
  served from the site root, but absolute is more portable.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>/about</loc>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>/features</loc>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>/privacy</loc>
    <changefreq>yearly</changefreq>
    <priority>0.4</priority>
  </url>
  <url>
    <loc>/terms</loc>
    <changefreq>yearly</changefreq>
    <priority>0.4</priority>
  </url>
</urlset>
