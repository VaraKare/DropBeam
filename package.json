{
  "name": "dropbeam",
  "private": true,
  "version": "0.1.0",
  "description": "Universal any-device-to-any-device file sharing platform.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:signaling": "cd apps/signaling && bun run dev",
    "start:signaling": "cd apps/signaling && bun run start",
    "cli": "bun apps/cli/src/index.ts",
    "test": "bun test",
    "test:protocol": "bun test packages/protocol",
    "test:transfer": "bun test packages/transfer",
    "test:signaling": "bun test apps/signaling",
    "e2e": "bash scripts/e2e.sh",
    "typecheck": "cd packages/protocol && bun run typecheck && cd ../transfer && bun run typecheck && cd ../../apps/signaling && bun run typecheck && cd ../cli && bun run typecheck && cd ../web && bun run typecheck",
    "dev:web": "cd apps/web && bun run dev",
    "build:web": "cd apps/web && bun run build",
    "lan": "cd apps/web && bun run build && cd ../signaling && WEB_ROOT=../web/dist bun run start"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "node-datachannel": "^0.32.2"
  }
}
